pipeline {
    agent any

    environment {
        APP_NAME = 'sample-app'
        TEST_ENV = 'test-environment'
    }

    stages {
        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                git url: 'https://github.com/vijayakhil13/jenkins_projects/sample-app.git', branch: 'main'
            }
        }

        stage('Build') {
            steps {
                echo 'Installing dependencies and building the app...'
                dir('sample-app') {
                sh 'npm install'
                sh 'npm run build'
            }}
        }

        stage('Test') {
            steps {
                echo 'Running tests...'
                sh 'npm test'
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: '**/test-results/results.xml'
                }
            }
        }

        stage('Package') {
            steps {
                echo "Packaging the app..."
                sh 'tar -czf ${APP_NAME}.tar.gz ./'
                archiveArtifacts artifacts: "${APP_NAME}.tar.gz", fingerprint: true
            }
        }

        stage('Deploy to Test') {
            steps {
                echo "Simulating deploy to ${TEST_ENV}..."
                sh "echo Deploying ${APP_NAME} to ${TEST_ENV} (simulated deploy)"
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
            // Add notification commands here like email, Slack, etc.
        }
        failure {
            echo 'Pipeline failed!'
            // Add failure notification commands here
        }
    }
}
